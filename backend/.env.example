# ── Databricks Connection ─────────────────────────────────────────────────────
# Full workspace URL (no trailing slash)
DATABRICKS_HOST=https://dbc-147ceb0b-b41d.cloud.databricks.com

# Personal access token from Databricks Settings → Access Tokens
DATABRICKS_TOKEN=dapi...

# SQL Warehouse HTTP path — found in SQL Warehouses → your warehouse → Connection Details
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/YOUR_WAREHOUSE_ID

# Unity Catalog coordinates
DATABRICKS_CATALOG=virtue_foundation
DATABRICKS_SCHEMA=ghana

# ── LLM & Embedding Endpoints ─────────────────────────────────────────────────
# Databricks Foundation Model API endpoint for LLaMA 3.3 70B
LLM_ENDPOINT=https://dbc-147ceb0b-b41d.cloud.databricks.com/serving-endpoints/databricks-meta-llama-3-3-70b-instruct/invocations

# BGE embedding endpoint for FAISS semantic search (leave blank to disable RAG)
EMBED_ENDPOINT=https://dbc-147ceb0b-b41d.cloud.databricks.com/serving-endpoints/databricks-bge-large-en/invocations

# LLM model name used in direct API calls
LLM_MODEL=databricks-meta-llama-3-3-70b-instruct

# ── Upstash Redis Caching ─────────────────────────────────────────────────────
# Get from console.upstash.com → Redis → your database → REST API
# Leave blank to fall back to no-op cache (app works without Redis)
UPSTASH_REDIS_REST_URL=https://YOUR-DB.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_UPSTASH_TOKEN

# ── FAISS Index Files ─────────────────────────────────────────────────────────
# Local paths (relative to backend directory) — used if files exist on disk
FAISS_INDEX_PATH=./rag_data/faiss_index.bin
FAISS_META_PATH=./rag_data/faiss_metadata.json

# Remote URLs — used if local files are missing (GitHub Releases recommended)
FAISS_INDEX_URL=https://github.com/YOUR_ORG/YOUR_REPO/releases/download/rag-index-latest/faiss_index.bin
FAISS_META_URL=https://github.com/YOUR_ORG/YOUR_REPO/releases/download/rag-index-latest/faiss_metadata.json

# ── Security ──────────────────────────────────────────────────────────────────
# 64-character random hex string — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme_generate_a_real_64_char_hex_string_before_deploying_production

# Comma-separated API keys for agent endpoint authentication
API_KEYS=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://your-frontend.vercel.app

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=20

# ── Agent Configuration ───────────────────────────────────────────────────────
AGENT_TIMEOUT_SECONDS=180

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Environment ───────────────────────────────────────────────────────────────
# development or production
ENVIRONMENT=development

# ── MLflow ────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=databricks
