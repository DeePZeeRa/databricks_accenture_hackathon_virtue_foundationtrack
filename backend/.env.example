# ── Virtue Foundation IDP — Environment Variables ──────────────────────────────
# Copy to .env and fill in values for local development.
# In Databricks Apps, all values come from app.yaml valueFrom bindings.

# Databricks workspace connection
DATABRICKS_HOST=https://dbc-147ceb0b-b41d.cloud.databricks.com
DATABRICKS_TOKEN=dapi...
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/YOUR_WAREHOUSE_ID
DATABRICKS_SQL_WAREHOUSE_ID=YOUR_WAREHOUSE_ID
DATABRICKS_CATALOG=virtue_foundation
DATABRICKS_SCHEMA=ghana

# LLM & Embedding (Databricks Model Serving)
LLM_MODEL=databricks-meta-llama-3-3-70b-instruct
LLM_ENDPOINT=https://dbc-147ceb0b-b41d.cloud.databricks.com/serving-endpoints/databricks-meta-llama-3-3-70b-instruct/invocations
EMBED_ENDPOINT=https://dbc-147ceb0b-b41d.cloud.databricks.com/serving-endpoints/databricks-bge-large-en/invocations

# Security (must be at least 32 characters)
SECRET_KEY=changeme_at_least_32_characters_long_for_production_use

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional Redis cache (leave blank to use in-memory)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# App environment
ENVIRONMENT=development
LOG_LEVEL=INFO
RATE_LIMIT_PER_MINUTE=20
AGENT_TIMEOUT_SECONDS=180
